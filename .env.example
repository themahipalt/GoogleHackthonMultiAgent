# ── Google AI (Gemini) ─────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# ── Google Cloud ───────────────────────────────────────────────────────────────
# Your GCP project ID
GOOGLE_CLOUD_PROJECT=my-project-id

# Path to service account JSON key (for Firestore + Calendar API)
# Create at: GCP Console → IAM → Service Accounts → Create Key (JSON)
# Roles needed: Cloud Datastore User, Calendar API access
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ── Google Calendar ────────────────────────────────────────────────────────────
# The calendar to write events into.
# Share your calendar with the service account email to enable real write access.
# Use "primary" for the service account's own calendar.
GOOGLE_CALENDAR_ID=primary

# ── Google Tasks ───────────────────────────────────────────────────────────────
# OAuth token file path (generated by running: python auth/oauth_setup.py)
# Leave blank to use Firestore for task storage instead.
GOOGLE_TASKS_TOKEN=./tokens/tasks_token.json
